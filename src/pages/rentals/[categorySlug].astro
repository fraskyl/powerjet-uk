---
import "../../styles/global.css";
import { sanityClient } from "../../lib/sanity";
import { 
  topLevelProductCategoriesQuery,
  allProductsWithCategoriesQuery,
  productTypeByCategorySlugQuery,
  categorySidebarQuery,
} from "../../lib/queries";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Layout/Header.astro";
import Footer from "../../components/Layout/Footer.astro";
import TextHero from "../../components/Sections/TextHero.astro";
import Card from "../../components/UI/Card.astro";
import ContactBlock from "../../components/Sections/ContactBlock.astro";
import CategorySidebar from "../../components/Navigation/CategorySidebar.astro";

export async function getStaticPaths() {
  try {
    // Use categorySidebarQuery instead — returns ALL categories at all levels
    const allCategories = await sanityClient.fetch(categorySidebarQuery, {
      availability: "rental"
    });
    console.log("✅ Generating sales category paths:", allCategories?.length || 0);
    return allCategories.map((category: any) => ({
      params: { categorySlug: category.slug }
    }));
  } catch (error) {
    console.error("❌ Error generating rentals category paths:", error);
    return [];
  }
}

const { categorySlug } = Astro.params;

// Fetch the current category, all products in it, and all top-level 
// rental categories (for the sidebar)
let category;
let products = [];
let allCategories = [];
let sidebarCategories = [];
let fetchError = false;

try {
  [category, products, allCategories, sidebarCategories] = await Promise.all([
    sanityClient.fetch(productTypeByCategorySlugQuery, { categorySlug }),
    sanityClient.fetch(allProductsWithCategoriesQuery, { availability: "rental" }),
    sanityClient.fetch(topLevelProductCategoriesQuery, { availability: "rental" }),
    sanityClient.fetch(categorySidebarQuery, { availability: "rental" })

  ]);

  // Filter products to only those in this category
 function getDescendantSlugs(allCats: any[], parentSlug: string): string[] {
  const children = allCats.filter(cat => cat.parentSlug === parentSlug);
  const childSlugs = children.map(cat => cat.slug);
  const descendantSlugs = children.flatMap(child => 
    getDescendantSlugs(allCats, child.slug)
  );
  return [...childSlugs, ...descendantSlugs];
}

const categoryAndDescendantSlugs = [
  categorySlug,
  ...getDescendantSlugs(sidebarCategories, categorySlug)
];

products = products.filter((product: any) =>
  categoryAndDescendantSlugs.includes(product.productCategory?.slug)
);

  console.log(`✅ Category: ${category?.title}, Products: ${products.length}`);
} catch (error) {
  console.error("❌ Error fetching category detail:", error);
  fetchError = true;
}

if (!category) return Astro.redirect("/rentals");

const title = `${category.title} | Rentals | Powerjet`;
---

<BaseLayout title={title}>
  <Header />
  <div class="page-grid">
    <TextHero headline={category.title} />

    {fetchError ? (
      <div class="error-message">
        <p>Unable to load products. Please try again later.</p>
      </div>
    ) : (
      <div class="category-layout">

        <!-- Sidebar -->
        <aside class="category-sidebar">
          <p class="sidebar-label">Categories</p>
          <CategorySidebar 
            categories={sidebarCategories} 
            currentSlug={categorySlug} 
            pageType="rental"
          />
        </aside>

        <!-- Products -->
        <div class="products-grid">
          {products.length > 0 ? (
            products.map((product: any) => (
              <Card
                imageURL={product.images?.[0]?.url || "/src/assets/New_Image_Magtrack-lrg.jpeg"}
                imageAlt={product.images?.[0]?.alt || product.title}
                href={`/products/${product.slug}`}
                buttonLabel={product.title}
                icon={true}
                style="light"
              />
            ))
          ) : (
            <p class="empty-state">No products in this category yet.</p>
          )}
        </div>

      </div>
    )}

    <ContactBlock />
  </div>
  <Footer />
</BaseLayout>

<style>
  .category-layout {
    grid-column: 2 / -2;
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    margin-bottom: 5rem;
  }

  /* Sidebar stacks above products on mobile */
  .category-sidebar {
    order: -1;
  }

  .sidebar-label {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--pj_blue_50);
    margin-bottom: 0.75rem;
    margin: 0 0 0.75rem 0;
  }

  .category-sidebar ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: row;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .sidebar-link {
    display: block;
    padding: 0.5rem 1rem;
    border: 1px solid var(--pj_blue_20);
    border-radius: 100px;
    font-size: 0.875rem;
    color: var(--pj_brand_blue);
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .sidebar-link:hover,
  .sidebar-link.active {
    background-color: var(--pj_brand_blue);
    color: white;
    border-color: var(--pj_brand_blue);
  }

  .products-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  .empty-state {
    color: var(--pj_blue_70);
    font-size: 1.125rem;
  }

  .error-message {
    grid-column: 2 / -2;
    text-align: center;
    padding: 3rem;
    color: var(--pj_blue_70);
  }

  @media screen and (min-width: 768px) {
    .category-sidebar ul {
      flex-direction: column;
      gap: 0.25rem;
    }

    .sidebar-link {
      border-radius: 0.25rem;
    }

    .products-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media screen and (min-width: 1024px) {
    .category-layout {
      grid-column: 2 / -2;
      grid-template-columns: 220px 1fr;
      align-items: start;
      gap: 4rem;
    }

    .category-sidebar {
      order: 0;
      position: sticky;
      top: 2rem;
    }

    .products-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>