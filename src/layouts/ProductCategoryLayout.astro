---
// src/layouts/ProductListingsLayout.astro
// Now shows category cards, not individual products

import "../styles/global.css";
import { sanityClient } from "../lib/sanity";
import { topLevelProductCategoriesQuery } from "../lib/queries";
import BaseLayout from "./BaseLayout.astro";
import Header from "../components/Layout/Header.astro";
import Footer from "../components/Layout/Footer.astro";
import TextHero from "../components/Sections/TextHero.astro";
import Card from "../components/UI/Card.astro";
import ContactBlock from "../components/Sections/ContactBlock.astro";

interface Props {
  pageType: "rental" | "sale";
  headline: string;
  subheadline?: string;
}

const { pageType, headline } = Astro.props;

let productTypes = [];

try {
  productTypes = await sanityClient.fetch(topLevelProductCategoriesQuery, {
    availability: pageType,
  });
} catch (error) {
  console.error(`❌ Error fetching product types:`, error);
}

const title = pageType === "rental" ? "Rentals | Powerjet" : "Sales | Powerjet";
---

<BaseLayout title={title}>
  <Header />
  <div class="page-grid">
    <TextHero headline={headline} />
    <div class="category-grid">
      {
        productTypes.map((type: any) => (
          <Card
            imageURL={
              type.coverImageUrl || "/src/assets/New_Image_Magtrack-lrg.jpeg"
            }
            imageAlt={type.coverImageAlt}
            href={`/${pageType === "rental" ? "rentals" : "sales"}/${type.slug}`}
            buttonLabel={type.title}
            icon={true}
            style="dark"
          />
        ))
      }
    </div>
    <ContactBlock />
  </div>
  <Footer />
</BaseLayout>

<style>
  .category-grid {
    grid-column: 2 / -2;
    display: grid;
    grid-template-columns: 1fr;
    column-gap: 2rem;
    row-gap: 6rem;
    margin-bottom: 5rem;
  }

  @media screen and (min-width: 768px) {
    .category-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media screen and (min-width: 1024px) {
    .category-grid {
      grid-column: 3 / -3;
      grid-template-columns: repeat(4, 1fr);
    }
  }
</style>
