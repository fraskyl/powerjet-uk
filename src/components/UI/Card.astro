---
interface Props {
  imageURL: string;
  imageAlt: string;
  href: string;
  buttonLabel: string;
  icon?: boolean;
  style?: "light" | "dark";
}

const { imageURL } = Astro.props;
const { imageAlt } = Astro.props;

const { href } = Astro.props;
const { buttonLabel } = Astro.props;

const { icon = true } = Astro.props;

const { style = "dark" } = Astro.props;
---

<div class="card__wrapper">
  <a href={href} class="card__link">
    <div class="card__wrapper">
      <div class="image__container">
        <img src={imageURL} alt={imageAlt} />
      </div>
      <div class="card__panel" data-variant={style} data-icon={icon}>
        {buttonLabel}
        {
          icon === true && (
            <span class="material-symbols-outlined">arrow_forward</span>
          )
        }
      </div>
    </div>
  </a>
</div>

<style>
  .card__link {
    text-decoration: none;
    color: inherit;
  }

  .card__wrapper {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    width: 100%;
    border-radius: 0.25rem;
  }

  .image__container {
    flex: 1;
    overflow: hidden;
    flex-shrink: 0;
  }

  .image__container img {
    object-fit: cover;
    display: block;
    width: 100%;
    height: 100%;
    transition: all 0.3s ease-in-out;
  }

  .card__panel {
    display: flex;
    flex-direction: row;
    justify-content: space-between;
    align-items: center;
    height: 64px;
    flex-shrink: 0;
    width: 100%;

    font-family: "Instrument Sans";
    font-size: 18px;
    font-style: normal;
    font-weight: 400;
    line-height: 28px; /* 155.556% */
    letter-spacing: -0.306px;
    color: var(--pj_brand_blue);

    position: relative;
    overflow: hidden;
  }

  /* Base border — always visible, resting colour */
  .card__panel::before {
    content: "";
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 1px;
    background-color: var(--pj_blue_20);
  }

  /* Hover colour overlay — sweeps left to right n etner and opposite on exit*/
  .card__panel::after {
    content: "";
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 1px;
    background-color: var(--pj_blue_90);
    transform: scaleX(0);
    transform-origin: right;
    transition: transform 0.5s ease;
  }

  /* Trigger on the parent wrapper hover, not the panel itself */
  .card__wrapper:hover .card__panel::after {
    transform: scaleX(1);
    transform-origin: left;
  }

  /* Light variant */
  .card__panel[data-variant="light"] {
    color: var(--pj_brand_blue);
  }

  .card__panel[data-variant="light"] .material-symbols-outlined {
    color: var(--pj_brand_blue);
  }

  .material-symbols-outlined {
    font-variation-settings:
      "FILL" 0,
      "wght" 400,
      "GRAD" 0,
      "opsz" 24;
    color: currentColor; /* Inherits from .card__panel */
  }

  .card__panel .material-symbols-outlined {
    font-variation-settings:
      "FILL" 0,
      "wght" 400,
      "GRAD" 0,
      "opsz" 24;
    color: currentColor;
    opacity: 0;
    transform: translateX(-4px);
    transition:
      opacity 0.3s ease,
      transform 0.3s ease;
  }

  .card__wrapper:hover .card__panel .material-symbols-outlined {
    opacity: 1;
    transform: translateX(0);
  }

  .card__wrapper:hover .card__panel {
    transition: background-color 0.3s ease;
  }

  .card__wrapper:hover .image__container img {
    transform: scale(1.05); /* Zoom in effect */
  }

  .material-symbols-outlined {
    font-variation-settings:
      "FILL" 0,
      "wght" 400,
      "GRAD" 0,
      "opsz" 24;
    color: white;
  }

  @media screen and (min-width: 768px) {
    .card__wrapper {
      height: 400px;
    }
  }
</style>
