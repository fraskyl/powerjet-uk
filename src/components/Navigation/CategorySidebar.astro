---
interface Category {
  title: string;
  slug: string;
  _id: string;
  parentId?: string;
  parentSlug?: string;
  children?: Category[];
}

interface Props {
  categories: Category[];
  currentSlug: string;
  pageType: "rental" | "sale";
  depth?: number;
}

const { categories, currentSlug, pageType, depth = 0 } = Astro.props;

// Build tree from flat list — only run at top level (depth === 0)
function buildTree(flatCategories: Category[]): Category[] {
  const map = new Map<string, Category>();
  const roots: Category[] = [];

  // First pass: map all categories by ID
  flatCategories.forEach((cat) => {
    map.set(cat._id, { ...cat, children: [] });
  });

  // Second pass: assign children to parents
  flatCategories.forEach((cat) => {
    const node = map.get(cat._id)!;
    if (cat.parentId) {
      const parent = map.get(cat.parentId);
      if (parent) {
        parent.children = parent.children || [];
        parent.children.push(node);
      }
    } else {
      roots.push(node);
    }
  });

  return roots;
}

// Only build the tree at the top level call
const tree = depth === 0 ? buildTree(categories) : categories;

// Check if current slug is within a branch (for expanding active parent)
function isActiveBranch(category: Category, currentSlug: string): boolean {
  if (category.slug === currentSlug) return true;
  return (
    category.children?.some((child) => isActiveBranch(child, currentSlug)) ??
    false
  );
}

const basePath = pageType === "rental" ? "/rentals" : "/sales";
---

<div class="sidebar-wrapper">
  <button
    class="sidebar-mobile-toggle"
    id="sidebar-toggle"
    aria-expanded="false"
  >
    <span class="toggle-label">
      <span class="material-symbols-outlined">filter_list</span>
      <span>Filter by category</span>
    </span>
    <span class="material-symbols-outlined toggle-chevron">expand_more</span>
  </button>

  <div class="sidebar-dropdown" id="sidebar-dropdown">
    <ul class:list={["sidebar-list", { "sidebar-list--nested": depth > 0 }]}>
      {
        tree.map((category) => {
          const hasChildren = category.children && category.children.length > 0;
          const isActive = category.slug === currentSlug;
          const isBranchActive = isActiveBranch(category, currentSlug);

          return (
            <li class:list={["sidebar-item", { "has-children": hasChildren }]}>
              <a
                href={`${basePath}/${category.slug}`}
                class:list={[
                  "sidebar-link",
                  { active: isActive },
                  { "branch-active": isBranchActive && !isActive },
                ]}
              >
                <span class="sidebar-checkbox" aria-hidden="true" />
                <span class="sidebar-label">{category.title}</span>
                {hasChildren && (
                  <span
                    class:list={[
                      "sidebar-chevron",
                      { rotated: isBranchActive },
                    ]}
                  >
                    <span class="material-symbols-outlined">chevron_right</span>
                  </span>
                )}
              </a>

              {hasChildren && isBranchActive && (
                <Astro.self
                  categories={category.children}
                  currentSlug={currentSlug}
                  pageType={pageType}
                  depth={depth + 1}
                />
              )}
            </li>
          );
        })
      }
    </ul>
  </div>
</div>

<style>
  /* Mobile toggle button */
  .sidebar-mobile-toggle {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    padding: 0.75rem 1rem;
    background: white;
    border: 1px solid var(--pj_blue_30);
    border-radius: 0.25rem;
    font-family: "Instrument Sans", sans-serif;
    font-size: 0.9375rem;
    color: var(--pj_brand_blue);
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .sidebar-mobile-toggle:hover {
    border-color: var(--pj_brand_blue);
    background-color: var(--pj_blue_05);
  }

  .toggle-label {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 500;
  }

  .toggle-chevron {
    transition: transform 0.3s ease;
  }

  .sidebar-mobile-toggle[aria-expanded="true"] .toggle-chevron {
    transform: rotate(180deg);
  }

  /* Mobile dropdown panel */
  .sidebar-dropdown {
    display: none;
    position: absolute;
    top: calc(100% + 0.25rem);
    left: 0;
    right: 0;
    background: white;
    border: 1px solid var(--pj_blue_30);
    border-radius: 0.25rem;
    box-shadow: 0 4px 12px rgba(0, 51, 102, 0.1);
    max-height: 60vh;
    overflow-y: auto;
    z-index: 100;
    padding: 0.5rem;
  }

  .sidebar-dropdown.open {
    display: block;
  }

  .sidebar-wrapper {
    position: relative; /* Anchor for absolute dropdown */
  }

  .sidebar-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: row;
    flex-wrap: wrap;
  }

  /* Nested lists always vertical */
  .sidebar-list--nested {
    flex-direction: column;
    flex-wrap: nowrap;
    padding-left: 1rem;
    margin-top: 0.5rem;
    gap: 0.25rem;
  }

  .sidebar-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.625rem;
    padding: 0.25rem 0rem;
    font-size: 0.875rem;
    color: var(--pj_brand_blue);
    text-decoration: none;
    transition: all 0.2s ease;
    width: 100%;
  }

  .sidebar-label {
    flex: 1;
  }

  .sidebar-checkbox {
    display: inline-flex;
    flex-shrink: 0;
    width: 0.75rem;
    height: 0.75rem;
    border: 1px solid var(--pj_blue_30);
    border-radius: 1px;
    transition: background-color 0.2 ease;
  }

  .sidebar-link:hover,
  .sidebar-link.active {
    background-color: transparent;
    color: var(--pj_brand_blue);
    font-weight: 500;
  }

  .sidebar-link.branch-active {
    border-color: var(--pj_brand_blue);
    font-weight: 500;
  }

  .sidebar-link.active .sidebar-checkbox,
  .sidebar-link.branch-active .sidebar-checkbox {
    background-color: var(--pj_blue_30);
  }

  .sidebar-chevron {
    display: inline-flex;
    transition: transform 0.2s ease;
  }

  .sidebar-chevron.rotated {
    transform: rotate(90deg);
  }

  .sidebar-chevron .material-symbols-outlined {
    font-size: 1rem;
  }

  /* Desktop: vertical layout */
  @media screen and (min-width: 768px) {
    .sidebar-list {
      flex-direction: column;
      flex-wrap: nowrap;
      gap: 0.25rem;
    }

    .sidebar-mobile-toggle {
      display: none;
    }

    .sidebar-dropdown {
      display: block; /* Always visible on desktop */
      position: static; /* Back in normal flow */
      border: none;
      box-shadow: none;
      padding: 0;
      max-height: none;
      overflow: visible;
    }
  }
</style>

<script>
  const toggle = document.getElementById("sidebar-toggle");
  const dropdown = document.getElementById("sidebar-dropdown");

  toggle?.addEventListener("click", () => {
    const isOpen = dropdown?.classList.contains("open");
    dropdown?.classList.toggle("open");
    toggle.setAttribute("aria-expanded", String(!isOpen));
  });

  // Close when clicking outside
  document.addEventListener("click", (e) => {
    if (
      !toggle?.contains(e.target as Node) &&
      !dropdown?.contains(e.target as Node)
    ) {
      dropdown?.classList.remove("open");
      toggle?.setAttribute("aria-expanded", "false");
    }
  });

  // Close on nav (page will reload anyway, but keeps it tidy)
  dropdown?.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", () => {
      dropdown.classList.remove("open");
      toggle?.setAttribute("aria-expanded", "false");
    });
  });
</script>
